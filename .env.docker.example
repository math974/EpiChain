# Copy to `.env` in the repo root and adjust values before: `docker compose up --build`

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=epichain
POSTGRES_PASSWORD=epichain
POSTGRES_DB=epichain
POSTGRES_PORT=5432

# --- Indexer ---
# In docker-compose, DATABASE_URL for the indexer container is set in docker-compose.yml (host `postgres`).
# For local `cd indexer && npm run dev` against Docker Postgres, use localhost in indexer/.env — see indexer/.env.example.
INDEXER_PORT=4000
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
START_BLOCK=0

# --- Frontend (baked in at image build time) ---
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_FACTORY_ADDRESS=0x3667e5E520bcd0aB07A7Fa0D43D6898DBbcAB8BE
VITE_COUNTER_ADDRESS=0xAe9fa1b26BfCf317DB03Fa71deCC8Bf9e4d0D0EB
# Optional override if you do local direct RPC reads from frontend
# VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Required for ERC-4337 UserOperation submission from frontend
# Example provider: Pimlico / Candide / Alchemy AA
VITE_BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_KEY

# Vite dev server (frontend Dockerfile `development` stage)
FRONTEND_PORT=5173

# Prisma Studio (docker compose service `prisma-studio`)
PRISMA_STUDIO_PORT=5555

# --- Contracts helper values (used by scripts in `contracts/`) ---
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ENTRY_POINT_V07=0x0000000071727De22E5E9d8BAf0edAc6f37da032
FACTORY_ADDRESS=0x3667e5E520bcd0aB07A7Fa0D43D6898DBbcAB8BE
COUNTER_ADDRESS=0xAe9fa1b26BfCf317DB03Fa71deCC8Bf9e4d0D0EB
