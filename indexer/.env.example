# PostgreSQL (local Docker, Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/epichain?schema=public"

# Ethereum Mainnet — required by the exam for indexing EntryPoint v0.7 events
MAINNET_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# EntryPoint v0.7 (fixed address on all supported chains)
ENTRY_POINT_ADDRESS="0x0000000071727De22E5E9d8BAf0edAc6f37da032"

# Backfill from this block (use a recent block to avoid hours of catch-up)
START_BLOCK="24900000"

# Max blocks per eth_getLogs request (Alchemy free = 10, paid = 2000+)
BATCH_SIZE="10"

# API
PORT="4000"
# For `docker build`, see `.env.build` (Prisma generate only; runtime uses compose env).
