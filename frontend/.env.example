# https://cloud.walletconnect.com — required for WalletConnect and RainbowKit
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: override default public RPCs (e.g. Alchemy Sepolia)
# VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional: ERC-4337 bundler RPC (Sepolia)
# VITE_BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_KEY

# Filled after deployment on Sepolia
VITE_FACTORY_ADDRESS=
VITE_COUNTER_ADDRESS=

# Indexer backend (for the Indexer Feed tab)
# VITE_INDEXER_URL=http://localhost:4000
# VITE_INDEXER_WS_URL=ws://localhost:4000/ws